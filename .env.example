# ─── SECURE ENV TEMPLATE — COPY TO .env AND FILL VALUES ───────────────────
# DO NOT COMMIT YOUR REAL .env FILE TO VERSION CONTROL (GITHUB/GITLAB)

# 1. Alchemy or Infura Sepolia RPC Endpoint URL
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY"

# 2. Your Metamask wallet private key (WITHOUT leading 0x prefix)
# DANGER: NEVER USE YOUR PRIMARY LIVE WALLET PRIVATE KEY. USE A DEVELOPMENT-ONLY ACCOUNT.
DEPLOYER_PRIVATE_KEY="your_dev_private_key_here"

# 3. Etherscan API Key for automated source verification (Optional but useful)
ETHERSCAN_API_KEY="your_etherscan_api_key_here"

# 4. Election Configuration
ELECTION_DURATION_MINUTES=60
